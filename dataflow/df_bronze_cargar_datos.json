{
	"name": "df_bronze_cargar_datos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "efectivos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "bronze_efectivos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_efectivo as string,",
				"          id_especialidad as string,",
				"          id_unidad_actual as string,",
				"          id_rango_actual as string,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as string,",
				"          estado as string,",
				"          salario_mensual as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(id_efectivo = toInteger(id_efectivo),",
				"          id_especialidad = toInteger(id_especialidad),",
				"          id_unidad_actual = toInteger(id_unidad_actual),",
				"          id_rango_actual = toInteger(id_rango_actual)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_efectivo as integer,",
				"          id_especialidad as integer,",
				"          id_unidad_actual as integer,",
				"          id_rango_actual as integer,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as string,",
				"          estado as string,",
				"          salario_mensual as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_efectivo,",
				"          id_especialidad,",
				"          id_unidad_actual,",
				"          id_rango_actual,",
				"          nombre,",
				"          ci,",
				"          fecha_nacimiento,",
				"          genero,",
				"          departamento_origen,",
				"          fecha_ingreso,",
				"          estado,",
				"          salario_mensual",
				"     )) ~> sink1"
			]
		}
	}
}