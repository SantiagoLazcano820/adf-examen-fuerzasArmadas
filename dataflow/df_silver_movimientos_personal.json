{
	"name": "df_silver_movimientos_personal",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_movimiento as string,",
				"          id_efectivo as string,",
				"          id_unidad_destino as string,",
				"          id_rango as string,",
				"          id_tipo_movimiento as string,",
				"          nombre_movimiento as string,",
				"          descripcion_movimiento as string,",
				"          fecha_movimiento as string,",
				"          antiguedad_anios as string,",
				"          salario_mensual as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    TRIM(M.id_movimiento) AS id_movimiento,\\n    TRIM(M.id_efectivo) AS id_efectivo,\\n    TRIM(M.id_unidad_destino) AS id_unidad_destino,\\n    TRIM(M.id_rango) AS id_rango,\\n    TRIM(M.id_tipo) AS id_tipo_movimiento,\\n    TRIM(T.nombre) AS nombre_movimiento,         \\n    TRIM(T.descripcion) AS descripcion_movimiento, \\n    TRIM(M.fecha_movimiento) AS fecha_movimiento,\\n    TRIM(M.antiguedad_anios) AS antiguedad_anios,\\n    TRIM(M.salario_mensual) AS salario_mensual,\\n    TRIM(M.observaciones) AS observaciones\\nFROM bronze.tbl_movimientos_personal M\\nLEFT JOIN bronze.tbl_tipos_movimiento T ON TRIM(M.id_tipo) = TRIM(T.id_tipo)\\nWHERE M.id_movimiento IS NOT NULL AND TRIM(M.id_movimiento) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(id_movimiento = iif(regexMatch(trim(id_movimiento), '^\\\\d+$'), toInteger(trim(id_movimiento)), toInteger(null())),",
				"          id_efectivo = toInteger(id_efectivo),",
				"          id_unidad_destino = toInteger(id_unidad_destino),",
				"          id_rango = toInteger(id_rango),",
				"          id_tipo_movimiento = toInteger(id_tipo_movimiento),",
				"          fecha_movimiento = coalesce(",
				"    toTimestamp(trim(fecha_movimiento), 'yyyy-MM-dd'),",
				"    toTimestamp(trim(fecha_movimiento), 'dd-MM-yyyy'),",
				"    toTimestamp(trim(fecha_movimiento), 'yyyy/MM/dd'),",
				"    toTimestamp(trim(fecha_movimiento), 'dd/MM/yyyy'),",
				"    toTimestamp(trim(fecha_movimiento), 'MM-dd-yyyy'),",
				"    toTimestamp(trim(fecha_movimiento), 'yyyyMMdd'),",
				"    toTimestamp('1900-01-01 00:00:00', 'yyyy-MM-dd HH:mm:ss')",
				"),",
				"          salario_mensual = toDecimal(regexReplace(regexReplace(trim(salario_mensual), '(?i)(BS\\\\.-|BS\\\\.|BS|\\\\s+)', ''), ',', ''), 18, 2),",
				"          antiguedad_anios = iif(regexMatch(upper(trim(antiguedad_anios)), '^(CERO|CERO AÑOS)$'), 0,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(UN|UNO|UN AÑO|1 AÑO)$'), 1,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(TRES|3 AÑOS)$'), 3,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(CUATRO)$'), 4,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(CINCO|CINCO AÑOS)$'), 5,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(SIETE|SIETE AÑOS)$'), 7,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(OCHO)$'), 8,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(DIEZ AÑOS)$'), 10,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(ONCE|ONCE AÑOS)$'), 11,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(DOCE|DOCE AÑOS)$'), 12,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(TRECE AÑOS)$'), 13,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(QUINCE)$'), 15,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(DIECISIETE)$'), 17,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(DIECIOCHO)$'), 18,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(VEINTE|VEINTE AÑOS)$'), 20,",
				"iif(regexMatch(upper(trim(antiguedad_anios)), '^(VEINTIDÓS)$'), 22,",
				"toInteger(round(toDecimal(regexExtract(replace(trim(antiguedad_anios), ',', '.'), '(\\\\d+(\\\\.\\\\d+)?)', 1), 18, 2)))",
				")))))))))))))))),",
				"          nombre_movimiento = initCap(nombre_movimiento),",
				"          observaciones = initCap(observaciones)) ~> derivedColumn1",
				"derivedColumn1 filter(!isNull(id_movimiento)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo_movimiento as integer,",
				"          nombre_movimiento as string,",
				"          descripcion_movimiento as string,",
				"          fecha_movimiento as timestamp,",
				"          antiguedad_anios as integer,",
				"          salario_mensual as decimal(18,2),",
				"          observaciones as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_movimiento,",
				"          id_efectivo,",
				"          id_unidad_destino,",
				"          id_rango,",
				"          id_tipo_movimiento,",
				"          nombre_movimiento,",
				"          descripcion_movimiento,",
				"          fecha_movimiento,",
				"          antiguedad_anios,",
				"          salario_mensual,",
				"          observaciones",
				"     )) ~> sink1"
			]
		}
	}
}