{
	"name": "df_silver_unidades",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_unidades",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_unidades",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_unit as string,",
				"          id_brigada as string,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    TRIM(id_unit) AS id_unit,\\n    TRIM(id_brigada) AS id_brigada,\\n    TRIM(nombre) AS nombre,\\n    TRIM(codigo) AS codigo,\\n    TRIM(ciudad) AS ciudad,\\n    TRIM(departamento) AS departamento,\\n    TRIM(tipo_cuartel) AS tipo_cuartel\\nFROM bronze.tbl_unidades\\nWHERE id_unit IS NOT NULL AND TRIM(id_unit) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(id_unit = toInteger(id_unit),",
				"          id_brigada = toInteger(id_brigada),",
				"          nombre = initCap(nombre),",
				"          tipo_cuartel = initCap(tipo_cuartel)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_unit as integer,",
				"          id_brigada as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_unit,",
				"          id_brigada,",
				"          nombre,",
				"          codigo,",
				"          ciudad,",
				"          departamento,",
				"          tipo_cuartel",
				"     )) ~> sink1"
			]
		}
	}
}