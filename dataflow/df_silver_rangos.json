{
	"name": "df_silver_rangos",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_rangos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_rangos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_rango as string,",
				"          nombre as string,",
				"          categoria as string,",
				"          nivel_jerarquico as string,",
				"          abreviatura as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    TRIM(id_rango) AS id_rango,\\n    TRIM(nombre) AS nombre,\\n    TRIM(categoria) AS categoria,\\n    TRIM(nivel_jerarquico) AS nivel_jerarquico,\\n    TRIM(abreviatura) AS abreviatura\\nFROM bronze.tbl_rangos\\nWHERE id_rango IS NOT NULL AND TRIM(id_rango) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(nivel_jerarquico = toInteger(nivel_jerarquico),",
				"          id_rango = toInteger(id_rango),",
				"          nombre = initCap(nombre)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_rango as integer,",
				"          nombre as string,",
				"          categoria as string,",
				"          nivel_jerarquico as integer,",
				"          abreviatura as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_rango,",
				"          nombre,",
				"          categoria,",
				"          nivel_jerarquico,",
				"          abreviatura",
				"     )) ~> sink1"
			]
		}
	}
}