{
	"name": "df_silver_estructura_organizacional",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_estrucutra_organizacional",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_estructura_organizacional",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_estructura as string,",
				"          id_padre as string,",
				"          nivel as string,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          cobertura_departamentos as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    TRIM(id_estructura) AS id_estructura,\\n    TRIM(id_padre) AS id_padre,\\n    TRIM(nivel) AS nivel,\\n    TRIM(nombre) AS nombre,\\n    TRIM(sigla) AS sigla,\\n    TRIM(tipo) AS tipo,\\n    TRIM(cobertura_departamentos) AS cobertura_departamentos\\nFROM bronze.tbl_estructura_organizacional\\nWHERE id_estructura IS NOT NULL AND TRIM(id_estructura) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(id_estructura = toInteger(id_estructura),",
				"          id_padre = toInteger(id_padre),",
				"          nivel = case(",
				"    trim(nivel) == 'rama', 1,",
				"    trim(nivel) == 'división' || trim(nivel) == 'division', 2,",
				"    trim(nivel) == 'brigada', 3,",
				"    0",
				"),",
				"          nombre = initCap(nombre),",
				"          tipo = initCap(tipo)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_estructura as integer,",
				"          id_padre as integer,",
				"          nivel as integer,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          cobertura_departamentos as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_estructura,",
				"          id_padre,",
				"          nivel,",
				"          nombre,",
				"          sigla,",
				"          tipo,",
				"          cobertura_departamentos",
				"     )) ~> sink1"
			]
		}
	}
}